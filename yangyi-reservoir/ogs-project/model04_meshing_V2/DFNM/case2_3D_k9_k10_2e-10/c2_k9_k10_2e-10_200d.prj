  <!-- Simulation starts at 2019-01-13 00:00:00; times are seconds after this date. -->
  <time_loop>
    <processes>
      <process ref="LF">
        <nonlinear_solver>basic_picard</nonlinear_solver>
        <convergence_criterion>
          <type>PerComponentDeltaX</type>
          <norm_type>NORM2</norm_type>
          <reltols>1e-3</reltols>
          <abstols>1e-6</abstols>
        </convergence_criterion>
        <time_discretization>
          <type>BackwardEuler</type>
        </time_discretization>
        <time_stepping>
          <type>FixedTimeStepping</type>
          <t_initial>0.0</t_initial>
          <t_end>17280000</t_end>
          <timesteps>
            <pair>
              <repeat>200</repeat>
              <delta_t>86400</delta_t>
            </pair>
          </timesteps>
        </time_stepping>
      </process>
    </processes>
    <output>
      <type>VTK</type>
                <prefix>case2_k9_k10_2e-10_200d</prefix>
      <timesteps>
        <pair>
          <repeat>200</repeat>
          <each_steps>1</each_steps>
        </pair>
      </timesteps>
      <fixed_output_times>0 86400 3542400 3974400 4579200 4924800 5184000 5529600 5788800 6134400 6393600 6825600 7430400 8121600 8640000 17280000</fixed_output_times>
      <variables>
        <variable>pressure</variable>
        <variable>DarcyVelocity</variable>
      </variables>
    </output>
  </time_loop>
  <nonlinear_solvers>
    <nonlinear_solver>
      <name>basic_picard</name>
      <type>Picard</type>
      <max_iter>20</max_iter>
      <linear_solver>general_linear_solver</linear_solver>
    </nonlinear_solver>
  </nonlinear_solvers>
  <linear_solvers>
    <linear_solver>
      <name>general_linear_solver</name>
      <eigen>
        <solver_type>SparseLU</solver_type>
        <scaling>true</scaling>
      </eigen>
    </linear_solver>
  </linear_solvers>
</OpenGeoSysProject>
